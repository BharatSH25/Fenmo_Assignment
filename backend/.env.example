# Backend environment variables
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# Absolute path to the SQLite database file.
# Locally: a file in the project root is fine.
# On Render: point this at a persistent disk mount, e.g. /data/fenmo.db
DB_PATH=./fenmo.db

# The exact origin of your deployed frontend.
# Locally this matches the Vite dev server default.
# On Render set it to your Vercel URL, e.g. https://fenmo.vercel.app
CORS_ORIGIN=http://localhost:5173
